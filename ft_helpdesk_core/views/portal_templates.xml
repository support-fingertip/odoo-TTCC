<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Portal Home: ticket count entry (hidden – moved to /my/support) ── -->
    <template id="portal_my_home_menu_ticket"
              name="Portal layout : helpdesk ticket menu entries"
              inherit_id="portal.portal_my_home"
              customize_show="True"
              active="False"
              priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">My Tickets</t>
                <t t-set="url">/my/tickets</t>
                <t t-set="count" t-value="ticket_count"/>
                <t t-set="placeholder_count">ticket_count</t>
            </t>
        </xpath>
    </template>

    <!-- ── /my/tickets – ticket list ───────────────────────────────────────── -->
    <template id="portal_my_tickets" name="My Helpdesk Tickets">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Tickets</t>
            </t>

            <t t-if="not tickets">
                <div class="alert alert-info mt-3">
                    You have no support tickets yet.
                </div>
            </t>
            <t t-if="tickets">
                <div class="card mt-3">
                    <div class="card-body p-0">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Ticket #</th>
                                    <th>Subject</th>
                                    <th>Project</th>
                                    <th>Status</th>
                                    <th>Priority</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="tickets" t-as="ticket">
                                    <tr>
                                        <td>
                                            <a t-attf-href="/my/tickets/#{ticket.id}">
                                                <t t-esc="ticket.ticket_no"/>
                                            </a>
                                        </td>
                                        <td>
                                            <a t-attf-href="/my/tickets/#{ticket.id}">
                                                <t t-esc="ticket.name"/>
                                            </a>
                                        </td>
                                        <td>
                                            <t t-esc="ticket.project_id.name or '-'"/>
                                        </td>
                                        <td>
                                            <span class="badge"
                                                  t-attf-class="badge
                                                    #{ticket.state == 'new' and 'text-bg-info' or ''}
                                                    #{ticket.state == 'open' and 'text-bg-primary' or ''}
                                                    #{ticket.state == 'pending_customer' and 'text-bg-warning' or ''}
                                                    #{ticket.state == 'resolved' and 'text-bg-success' or ''}
                                                    #{ticket.state in ('closed', 'cancelled') and 'text-bg-secondary' or ''}">
                                                <t t-esc="dict(ticket._fields['state'].selection).get(ticket.state, ticket.state)"/>
                                            </span>
                                        </td>
                                        <td>
                                            <t t-esc="dict(ticket._fields['priority'].selection).get(ticket.priority, ticket.priority)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div t-if="pager" class="o_portal_pager text-center mt-3">
                    <t t-call="portal.pager"/>
                </div>
            </t>
        </t>
    </template>

    <!-- ── /my/tickets/<id> – ticket detail with Milestones tab ─────────────── -->
    <template id="portal_ticket_detail" name="Ticket Detail">
        <t t-call="portal.portal_layout">
            <t t-set="o_portal_fullwidth_alert" t-value="True"/>

            <!-- breadcrumb -->
            <t t-set="title" t-value="ticket.name"/>

            <div class="row mt-3">
                <div class="col-12 col-lg-8">

                    <!-- Ticket header card -->
                    <div class="card mb-3">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <span class="text-muted me-2" style="font-size:0.85rem;">
                                    <t t-esc="ticket.ticket_no"/>
                                </span>
                                <t t-esc="ticket.name"/>
                            </h5>
                            <span class="badge"
                                  t-attf-class="badge
                                    #{ticket.state == 'new' and 'text-bg-info' or ''}
                                    #{ticket.state == 'open' and 'text-bg-primary' or ''}
                                    #{ticket.state == 'pending_customer' and 'text-bg-warning' or ''}
                                    #{ticket.state == 'resolved' and 'text-bg-success' or ''}
                                    #{ticket.state in ('closed', 'cancelled') and 'text-bg-secondary' or ''}">
                                <t t-esc="dict(ticket._fields['state'].selection).get(ticket.state, ticket.state)"/>
                            </span>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Project</dt>
                                <dd class="col-sm-9">
                                    <t t-esc="ticket.project_id.name or '-'"/>
                                </dd>
                                <dt class="col-sm-3">Priority</dt>
                                <dd class="col-sm-9">
                                    <t t-esc="dict(ticket._fields['priority'].selection).get(ticket.priority, ticket.priority)"/>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <!-- Tab strip: Description | Milestones -->
                    <ul class="nav nav-tabs" id="ticketTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="tab-desc" data-bs-toggle="tab"
                                    data-bs-target="#pane-desc" type="button" role="tab">
                                Description
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="tab-milestones" data-bs-toggle="tab"
                                    data-bs-target="#pane-milestones" type="button" role="tab">
                                Milestones
                                <t t-if="milestones">
                                    <span class="badge text-bg-secondary ms-1">
                                        <t t-esc="len(milestones)"/>
                                    </span>
                                </t>
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content border border-top-0 p-3 rounded-bottom mb-3" id="ticketTabContent">

                        <!-- Description pane -->
                        <div class="tab-pane fade show active" id="pane-desc" role="tabpanel">
                            <t t-if="ticket.description">
                                <div t-raw="ticket.description"/>
                            </t>
                            <t t-else="">
                                <p class="text-muted">No description provided.</p>
                            </t>
                        </div>

                        <!-- Milestones pane -->
                        <div class="tab-pane fade" id="pane-milestones" role="tabpanel">
                            <t t-if="milestones">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>ID</th>
                                            <th>Milestone</th>
                                            <th>Amount</th>
                                            <th>Paid</th>
                                            <th>Due Date</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="milestones" t-as="m">
                                            <tr>
                                                <td><t t-esc="m.milestone_id or '-'"/></td>
                                                <td><t t-esc="m.name"/></td>
                                                <td><t t-esc="'%.2f' % m.amount"/></td>
                                                <td><t t-esc="'%.2f' % m.paid_amount"/></td>
                                                <td>
                                                    <t t-if="m.due_date">
                                                        <t t-esc="m.due_date" t-options='{"widget": "date"}'/>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </td>
                                                <td>
                                                    <t t-if="m.status == 'paid'">
                                                        <span class="badge text-bg-success">Paid</span>
                                                    </t>
                                                    <t t-elif="m.status == 'partially_paid'">
                                                        <span class="badge text-bg-info">Partially Paid</span>
                                                    </t>
                                                    <t t-elif="m.status == 'invoice_raised'">
                                                        <span class="badge text-bg-warning">Invoice Raised</span>
                                                    </t>
                                                    <t t-elif="m.status == 'completed'">
                                                        <span class="badge text-bg-primary">Completed</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge text-bg-secondary">Not Started</span>
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <p class="text-muted">No milestones have been set for this ticket yet.</p>
                            </t>
                        </div>

                    </div>
                    <!-- end tab-content -->

                </div>
            </div>
        </t>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Email template sent to the customer when a new ticket is created -->
        <record id="mt_ticket_new_email_template" model="mail.template">
            <field name="name">Helpdesk Ticket: New Ticket Confirmation</field>
            <field name="model_id" ref="ft_helpdesk_core.model_ft_helpdesk_ticket"/>
            <field name="subject">Ticket {{ object.ticket_no }} - Confirmation</field>
            <field name="partner_to">{{ object.customer_id.id }}</field>
            <field name="body_html"><![CDATA[
<p>Dear {{ object.customer_id.name }},</p>
<p>Thank you for contacting us. Your support ticket has been created successfully.</p>
<table style="border-collapse: collapse; width: 100%; margin: 16px 0;">
    <tr>
        <td style="padding: 8px; font-weight: bold; width: 150px;">Ticket Number:</td>
        <td style="padding: 8px;">{{ object.ticket_no }}</td>
    </tr>
    <tr>
        <td style="padding: 8px; font-weight: bold;">Subject:</td>
        <td style="padding: 8px;">{{ object.name }}</td>
    </tr>
    {% if object.description %}
    <tr>
        <td style="padding: 8px; font-weight: bold; vertical-align: top;">Description:</td>
        <td style="padding: 8px;">{{ object.description | safe }}</td>
    </tr>
    {% endif %}
</table>
<p>Our support team will review your request and get back to you as soon as possible.</p>
<p>Best regards,<br/>{{ object.company_id.name }} Support Team</p>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>

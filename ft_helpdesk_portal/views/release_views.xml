<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_ft_helpdesk_release_list" model="ir.ui.view">
        <field name="name">ft.helpdesk.release.list</field>
        <field name="model">ft.helpdesk.release</field>
        <field name="arch" type="xml">
            <list string="Releases">
                <field name="name"/>
                <field name="version"/>
                <field name="project_id"/>
                <field name="release_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ft_helpdesk_release_form" model="ir.ui.view">
        <field name="name">ft.helpdesk.release.form</field>
        <field name="model">ft.helpdesk.release</field>
        <field name="arch" type="xml">
            <form string="Release">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="version"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="release_date"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ft_helpdesk_release" model="ir.actions.act_window">
        <field name="name">Releases</field>
        <field name="res_model">ft.helpdesk.release</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu under Project -->
    <menuitem id="menu_ft_helpdesk_release"
              name="Releases"
              parent="project.menu_main_pm"
              action="action_ft_helpdesk_release"
              sequence="35"/>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================== -->
    <!-- Force login form visible (Odoo 18     -->
    <!-- hides it behind OWL user_switch)      -->
    <!-- ===================================== -->
    <template id="ft_login_form_visible" name="FT Login Form Always Visible"
              inherit_id="web.login" priority="99">
        <!-- Remove the OWL user_switch component -->
        <xpath expr="//owl-component[@name='web.user_switch']" position="replace"/>
        <!-- Always show the login form (remove d-none toggle) -->
        <xpath expr="//form[@role='form']" position="attributes">
            <attribute name="t-attf-class">oe_login_form</attribute>
        </xpath>
    </template>

    <!-- ===================================== -->
    <!-- Custom Login Page (Salesforce-style)   -->
    <!-- Inherits web.login_layout AFTER the   -->
    <!-- website module replaces the container  -->
    <!-- ===================================== -->
    <template id="ft_login_page" name="FT Custom Login"
              inherit_id="web.login_layout" priority="99">

        <xpath expr="//div[hasclass('oe_website_login_container')]" position="replace">
            <!-- Hide website header/footer on login page -->
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>

            <div class="ft-login-wrapper">
                <!-- LEFT: Branding Panel -->
                <div class="ft-login-left">
                    <div class="ft-login-left-inner">
                        <div class="ft-login-brand-logo-wrap">
                            <img t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}"
                                 alt="Company Logo" class="ft-login-brand-logo"/>
                        </div>

                        <h1 class="ft-login-welcome">
                            Welcome to<br/>
                            <span>Your Support Portal</span>
                        </h1>
                        <p class="ft-login-tagline">
                            Track tickets, view milestones, and stay
                            updated on releases &#8212; all in one place.
                        </p>

                        <!-- SVG Laptop Illustration -->
                        <div class="ft-login-illustration">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 200" fill="none">
                                <!-- Laptop screen -->
                                <rect x="45" y="18" width="190" height="125" rx="8" fill="#1e0e45" stroke="#6c5ce7" stroke-width="1.5"/>
                                <rect x="55" y="28" width="170" height="105" rx="4" fill="#261356"/>
                                <!-- Window buttons -->
                                <circle cx="67" cy="37" r="3" fill="#ef4444" opacity="0.8"/>
                                <circle cx="78" cy="37" r="3" fill="#f59e0b" opacity="0.8"/>
                                <circle cx="89" cy="37" r="3" fill="#22c55e" opacity="0.8"/>
                                <!-- Dashboard bars -->
                                <rect x="68" y="95" width="22" height="30" rx="3" fill="#6c5ce7" opacity="0.7"/>
                                <rect x="97" y="78" width="22" height="47" rx="3" fill="#a855f7" opacity="0.6"/>
                                <rect x="126" y="65" width="22" height="60" rx="3" fill="#6c5ce7" opacity="0.85"/>
                                <rect x="155" y="85" width="22" height="40" rx="3" fill="#a855f7" opacity="0.5"/>
                                <rect x="184" y="55" width="22" height="70" rx="3" fill="#6c5ce7" opacity="0.65"/>
                                <!-- Trend line -->
                                <polyline points="79,90 108,73 137,60 166,80 195,50" stroke="#c4b5fd" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                                <!-- Laptop base -->
                                <path d="M35 143 L245 143 L258 160 L22 160 Z" fill="#1a0a3e"/>
                                <line x1="22" y1="160" x2="258" y2="160" stroke="#3b2872" stroke-width="1"/>
                                <line x1="118" y1="151" x2="162" y2="151" stroke="#3b2872" stroke-width="1.5" stroke-linecap="round"/>
                                <!-- Green checkmark badge -->
                                <circle cx="55" cy="28" r="16" fill="#22c55e"/>
                                <path d="M47 28 L52 33 L63 22" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                                <!-- Floating card -->
                                <rect x="210" y="42" width="52" height="34" rx="6" fill="rgba(108,92,231,0.35)" stroke="#6c5ce7" stroke-width="0.8"/>
                                <rect x="218" y="50" width="28" height="3.5" rx="1.5" fill="#c4b5fd" opacity="0.7"/>
                                <rect x="218" y="57" width="18" height="3.5" rx="1.5" fill="#a855f7" opacity="0.5"/>
                                <rect x="218" y="64" width="34" height="3.5" rx="1.5" fill="#c4b5fd" opacity="0.35"/>
                            </svg>
                        </div>

                        <p class="ft-login-copyright">
                            &#169; 2026 FingertipTech - Powered by Innovation
                        </p>
                    </div>
                </div>

                <!-- RIGHT: Login Form Panel -->
                <div class="ft-login-right">
                    <div class="ft-login-right-inner">
                        <h2 class="ft-login-form-title">Sign In</h2>
                        <p class="ft-login-form-subtitle">
                            Enter your credentials to access the portal
                        </p>
                        <div class="ft-login-card">
                            <!-- Inject the original Odoo login form (web.login content) -->
                            <t t-out="0"/>
                        </div>
                        <p class="ft-login-powered">Powered by Odoo</p>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
